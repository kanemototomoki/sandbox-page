{
  "name": "sandbox-page",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "start": "next start",
    "build": "npm run type-check && next build && next export -o dist",
    "lint": "next lint --dir src",
    "lint:fix": "npm run lint --fix",
    "format": "prettier --write --ignore-path .gitignore './**/*.{js,jsx,ts,tsx,json}'",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "next": "^13.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@code-hike/mdx": "^0.7.5-next.0",
    "@mdx-js/loader": "^2.1.3",
    "@next/mdx": "^12.3.0",
    "@swc/core": "^1.2.248",
    "@testing-library/jest-dom": "^5.16.5",
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^14.4.3",
    "@types/node": "18.7.15",
    "@types/react": "18.0.18",
    "@types/react-dom": "18.0.6",
    "eslint": "8.23.0",
    "eslint-config-next": "^13.0.0",
    "jest": "^29.0.2",
    "jest-dom": "^4.0.0",
    "jest-environment-jsdom": "^29.0.2",
    "msw": "^0.47.0",
    "normalize.css": "^8.0.1",
    "prettier": "^2.7.1",
    "typescript": "4.8.2",
    "whatwg-fetch": "^3.6.2"
  },
  "engines": {
    "node": "16.x"
  }
}
